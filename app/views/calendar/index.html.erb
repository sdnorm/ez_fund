<div class="max-w-3xl mx-auto p-4 mt-16">
  <h1 class="text-xl font-bold mb-4"><%= @participant.first_name %>'s Calendar</h1>

  <div class="mb-8">
    <%= render "calendar", { calendar: @calendar, calendar_days: @calendar_days, campaign_participant: @campaign_participant, campaign: @campaign } %>
  </div>

  <div class="mt-8">
    <div class="flex gap-4">
      <div class="flex items-center">
        <div class="w-4 h-4 bg-gray-300 rounded mr-2"></div>
        <div>Already Taken</div>
      </div>
      <div class="flex items-center">
        <div class="w-4 h-4 bg-yellow-200 rounded mr-2"></div>
        <div>In Process</div>
      </div>
    </div>
  </div>

  <% if @show_new_calendar_link %>
    <div class="mt-4">
      <%= link_to "Start New Calendar", calendar_path(calendar_number: @next_calendar_number), class: "text-blue-500 hover:text-blue-700" %>
    </div>
  <% end %>
</div>