<%= turbo_frame_tag "calendar" do %>
  <h1>Calendar Cookie ID: <%= @cookie_id %></h1>
  <div class="max-w-3xl mx-auto">
    <% if @selected_days.present? %>
      <div class="mb-6">
        <h2 class="text-lg font-semibold mb-2">Your Selected Days:</h2>
        <div class="flex gap-2 flex-wrap">
          <% @selected_days.each do |day| %>
            <div class="bg-blue-500 text-white px-3 py-1 rounded">
              <%= day.day %>
              <% if @current_calendar_session.present? %>
                <%= calendar_day_status_class(day.status, current_calendar_session: @current_calendar_session.id) %>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>

      <div class="mb-6">
        <h2 class="text-lg font-semibold mb-2">Total:</h2>
        <div class="flex gap-2 flex-wrap">
          <div class="bg-blue-500 text-white px-3 py-1 rounded">
            <%= number_to_currency(@total) %>
          </div>
        </div>
      </div>
    <% end %>

    <div class="grid grid-cols-7 gap-2">
      <% calendar_days.each do |calendar_day| %>
        <%= render "day", { calendar_day: calendar_day, campaign_participant: campaign_participant, campaign: campaign } %>
      <% end %>
    </div>
  </div>
<% end %>