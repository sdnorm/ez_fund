<div class="mx-auto md:w-2/3 w-full">
  <h1 class="font-bold text-4xl">Editing campaign</h1>

  <%= render "form", campaign: @campaign %>

  <%= button_to "Delete campaign", organization_campaign_path(@organization, @campaign), method: :delete, class: "rounded-md bg-red-50 px-3 py-2 text-sm font-semibold text-red-700 shadow-sm ring-1 ring-inset ring-red-700/10 hover:bg-red-100", data: { turbo_confirm: "Are you sure?" } %>
  <%= link_to "Show this campaign", organization_campaign_path(@organization, @campaign), class: "ml-2 rounded-lg py-3 px-5 bg-gray-100 inline-block font-medium" %>
  <%= link_to "Back to campaigns", organization_campaigns_path(@organization), class: "ml-2 rounded-lg py-3 px-5 bg-gray-100 inline-block font-medium" %>
</div>
