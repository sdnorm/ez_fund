<%= form_with(model: [@organization, campaign], class: "space-y-6") do |form| %>
  <% if campaign.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-4 py-3 rounded-lg">
      <h2 class="font-semibold"><%= pluralize(campaign.errors.count, "error") %> prohibited this campaign from being saved:</h2>
      <ul class="list-disc list-inside mt-2">
        <% campaign.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="space-y-6">
    <div>
      <%= form.label :name, "Name", class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :name, 
          class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500",
          placeholder: "Enter campaign name" %>
    </div>

    <div>
      <%= form.label :goal, "Goal", class: "block text-sm font-medium text-gray-700" %>
      <%= form.number_field :goal, 
          class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500",
          placeholder: "Enter campaign goal" %>
    </div>

    <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-2">
      <div>
        <%= form.label :start_date, "Start date", class: "block text-sm font-medium text-gray-700" %>
        <%= form.date_field :start_date, 
            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>

      <div>
        <%= form.label :end_date, "End date", class: "block text-sm font-medium text-gray-700" %>
        <%= form.date_field :end_date, 
            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>
    </div>

    <div>
      <%= form.label :description, "Description", class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_area :description, rows: 4, 
          class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500",
          placeholder: "Describe your campaign..." %>
      <p class="mt-2 text-sm text-gray-500">Brief description of your campaign's goals and purpose.</p>
    </div>

    <div class="relative flex items-start">
      <div class="flex items-center h-5">
        <%= form.check_box :active, class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" %>
      </div>
      <div class="ml-3 text-sm">
        <%= form.label :active, "Active Status", class: "font-medium text-gray-700" %>
        <p class="text-gray-500">Make this campaign visible to participants</p>
      </div>
    </div>

    <div class="flex justify-end gap-4">
      <%= link_to "Cancel", organization_campaigns_path(@organization), 
          class: "px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50" %>
      <%= form.submit "Create Campaign", 
          class: "px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-md hover:bg-blue-700" %>
    </div>
  </div>
<% end %>
