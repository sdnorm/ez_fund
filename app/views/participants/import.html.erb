<div class="min-h-screen bg-white">
  <div class="px-4 py-4 sm:px-6 lg:px-8">
    <%= link_to organization_campaign_participants_path(@organization, @campaign), 
        class: "rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 inline-flex items-center" do %>
      <svg class="-ml-0.5 mr-1.5 h-5 w-5 text-gray-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M17 10a.75.75 0 01-.75.75H5.612l4.158 3.96a.75.75 0 11-1.04 1.08l-5.5-5.25a.75.75 0 010-1.08l5.5-5.25a.75.75 0 111.04 1.08L5.612 9.25H16.25A.75.75 0 0117 10z" clip-rule="evenodd" />
      </svg>
      Back to <%= @campaign.name %> campaign participants
    <% end %>
  </div>

  <div class="px-4 py-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl">
      <div class="rounded-lg bg-white shadow">
        <div class="px-4 py-5 sm:p-6">
          <h3 class="text-lg font-medium leading-6 text-gray-900">Import Participants for <%= @campaign.name %></h3>
          
          <div class="mt-2 max-w-xl text-sm text-gray-500">
            <p>Upload a CSV file with the following columns: first_name, last_name, champion</p>
          </div>

          <%= form_tag process_import_organization_campaign_participants_path(@organization, @campaign), 
              multipart: true, 
              class: "mt-5",
              data: { controller: "dropzone", dropzone_target: "form" } do %>
            
            <div class="col-span-full">
              <div class="mt-2 flex justify-center rounded-lg border border-dashed border-gray-900/25 px-6 py-10"
                   data-controller="dropzone">
                <div class="text-center">
                  <svg class="mx-auto h-12 w-12 text-gray-300" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M1.5 6a2.25 2.25 0 0 1 2.25-2.25h16.5A2.25 2.25 0 0 1 22.5 6v12a2.25 2.25 0 0 1-2.25 2.25H3.75A2.25 2.25 0 0 1 1.5 18V6ZM3 16.06V18c0 .414.336.75.75.75h16.5A.75.75 0 0 0 21 18v-1.94l-2.69-2.689a1.5 1.5 0 0 0-2.12 0l-.88.879.97.97a.75.75 0 1 1-1.06 1.06l-5.16-5.159a1.5 1.5 0 0 0-2.12 0L3 16.061Zm10.125-7.81a1.125 1.125 0 1 1 2.25 0 1.125 1.125 0 0 1-2.25 0Z" clip-rule="evenodd" />
                  </svg>
                  
                  <div class="mt-4 flex text-sm/6 text-gray-600 justify-center">
                    <button type="button" 
                            class="relative cursor-pointer rounded-md bg-white font-semibold text-indigo-600 focus-within:outline-none focus-within:ring-2 focus-within:ring-indigo-600 focus-within:ring-offset-2 hover:text-indigo-500"
                            data-action="click->dropzone#browse">
                      <span>Upload a file</span>
                    </button>
                    <p class="pl-1">or drag and drop</p>
                    
                    <%= file_field_tag :file, 
                        accept: ".csv",
                        class: "sr-only",
                        required: true,
                        data: {
                          dropzone_target: "input",
                          action: "change->dropzone#fileChosen"
                        } %>
                  </div>
                  
                  <div data-dropzone-target="preview" class="mt-2 text-sm text-gray-600">
                    Choose a CSV file or drag it here
                  </div>
                </div>
              </div>
            </div>

            <div class="mt-5 flex justify-end gap-x-3">
              <%= link_to "Cancel", 
                  organization_campaign_path(@organization, @campaign), 
                  class: "rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" %>
              
              <%= submit_tag "Upload Participants", 
                  class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div> 